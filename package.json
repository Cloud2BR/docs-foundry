{
  "name": "docfoundry",
  "version": "0.0.1",
  "description": "DocsFoundry - open-source documentation workspace desktop app",
  "main": "src/main.js",
  "license": "MIT",
  "author": {
    "name": "brown9804",
    "email": "brown9804@outlook.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cloud2BR/docs-foundry"
  },
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_ENABLE_LOGGING=1 electron . --watch",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "bash build/generate-icons.sh",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.docfoundry.app",
    "productName": "DocsFoundry",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "icon": "build/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "Cloud2BR",
        "repo": "docs-foundry"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "mermaid": "^10.9.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "vitest": "^3.0.0"
  }
}
